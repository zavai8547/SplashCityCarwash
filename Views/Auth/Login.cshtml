@model SplashCityCarwash.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kujaributuu Carwash — Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #1565C0 0%, #42A5F5 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            font-family: Arial, sans-serif;
        }

        .login-wrapper {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            width: 100%;
            max-width: 900px;
            min-height: 520px;
            display: flex;
            box-shadow: 0 25px 60px rgba(0,0,0,0.3);
        }

        /* LEFT SIDE — Logo */
        .login-left {
            flex: 1;
            background: linear-gradient(160deg, #1565C0, #0D47A1);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px 30px;
            position: relative;
            overflow: hidden;
        }

            .login-left::before {
                content: '';
                position: absolute;
                width: 300px;
                height: 300px;
                background: rgba(255,255,255,0.05);
                border-radius: 50%;
                top: -100px;
                left: -100px;
            }

            .login-left::after {
                content: '';
                position: absolute;
                width: 200px;
                height: 200px;
                background: rgba(255,255,255,0.05);
                border-radius: 50%;
                bottom: -60px;
                right: -60px;
            }

            .login-left img {
                width: 100%;
                max-width: 260px;
                object-fit: contain;
                position: relative;
                z-index: 1;
                filter: drop-shadow(0 8px 24px rgba(0,0,0,0.3));
            }

            .login-left h2 {
                color: white;
                font-size: 1.4rem;
                font-weight: 800;
                text-align: center;
                margin-top: 20px;
                position: relative;
                z-index: 1;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

            .login-left p {
                color: #FFD600;
                font-size: 0.9rem;
                text-align: center;
                margin-top: 6px;
                position: relative;
                z-index: 1;
            }

        /* RIGHT SIDE — Form */
        .login-right {
            flex: 1;
            padding: 50px 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

            .login-right h3 {
                color: #1565C0;
                font-weight: 800;
                font-size: 1.8rem;
                margin-bottom: 6px;
            }

            .login-right .subtitle {
                color: #888;
                font-size: 0.9rem;
                margin-bottom: 32px;
            }

        .yellow-line {
            width: 50px;
            height: 4px;
            background: #FFD600;
            border-radius: 2px;
            margin-bottom: 24px;
        }

        .form-label {
            font-weight: 600;
            color: #333;
            font-size: 0.9rem;
        }

        .form-control {
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 0.95rem;
            transition: border-color 0.2s;
        }

            .form-control:focus {
                border-color: #1565C0;
                box-shadow: 0 0 0 3px rgba(21,101,192,0.1);
            }

        .password-wrapper {
            position: relative;
        }

        .toggle-pw {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            font-size: 18px;
            color: #888;
            padding: 0;
        }

        .btn-login {
            background: linear-gradient(135deg, #1565C0, #42A5F5);
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            transition: opacity 0.2s, transform 0.1s;
        }

            .btn-login:hover {
                opacity: 0.92;
                transform: translateY(-1px);
            }

            .btn-login:active {
                transform: translateY(0);
            }

        .setup-link {
            text-align: center;
            margin-top: 16px;
            font-size: 0.85rem;
            color: #aaa;
        }

            .setup-link a {
                color: #1565C0;
            }

        /* MOBILE */
        @@media (max-width: 650px) {
            .login-wrapper {
                flex-direction: column;
                min-height: auto;
            }

            .login-left {
                padding: 30px 20px;
                min-height: 220px;
            }

                .login-left img {
                    max-width: 160px;
                }

                .login-left h2 {
                    font-size: 1.1rem;
                }

            .login-right {
                padding: 30px 24px;
            }
        }
    </style>
</head>
<body>
    <div class="login-wrapper">

        <!-- LEFT — Logo -->
        <div class="login-left">
            <img src="/images/logo.png" alt="Kujaributuu Carwash Logo" />
            <h2>Kujaributuu</h2>
            <p>Carwash & Detailing</p>
        </div>

        <!-- RIGHT — Form -->
        <div class="login-right">
            <h3>Welcome Back</h3>
            <p class="subtitle">Sign in to manage your carwash</p>
            <div class="yellow-line"></div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success mb-3">@TempData["Success"]</div>
            }

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger mb-3"
                     style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")">
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email" class="form-control"
                           placeholder="your@email.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Password</label>
                    <div class="password-wrapper">
                        <input asp-for="Password" class="form-control"
                               id="passwordField"
                               placeholder="Enter your password" />
                        <button type="button" class="toggle-pw"
                                onclick="togglePassword()" title="Show/hide password">
                            👁️
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"
                           style="font-size:0.9rem; color:#666;">
                        Remember me on this device
                    </label>
                </div>

                <button type="submit"
                        class="btn btn-login w-100 text-white">
                    Sign In →
                </button>
            </form>

            <div class="setup-link">
                First time setup?
                <a href="/Auth/SeedAdmin">Create admin account</a>
            </div>
        </div>
    </div>

    <script>
        function togglePassword() {
            const field = document.getElementById('passwordField');
            const btn = document.querySelector('.toggle-pw');
            if (field.type === 'password') {
                field.type = 'text';
                btn.textContent = '🙈';
            } else {
                field.type = 'password';
                btn.textContent = '👁️';
            }
        }
    </script>
</body>
</html>