@model SplashCityCarwash.Models.Product
@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">✏️ Edit Product</h5>
            </div>
            <div class="card-body">
                <form asp-action="EditProduct" method="post">
                    <input type="hidden" asp-for="ProductID" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Product Name *</label>
                        <input asp-for="Name" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Category</label>
                        <input asp-for="Category" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <input asp-for="Description" class="form-control" />
                    </div>

                    <div class="row">
                        <div class="col mb-3">
                            <label class="form-label fw-semibold">
                                Buying Price (KES) *
                            </label>
                            <input asp-for="BuyingPrice" type="number"
                                   class="form-control" step="0.01" required />
                        </div>
                        <div class="col mb-3">
                            <label class="form-label fw-semibold">
                                Selling Price (KES) *
                            </label>
                            <input asp-for="SellingPrice" type="number"
                                   class="form-control" step="0.01" required />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col mb-3">
                            <label class="form-label fw-semibold">Unit</label>
                            <select asp-for="Unit" class="form-select">
                                <option value="piece">Piece</option>
                                <option value="litre">Litre</option>
                                <option value="kg">KG</option>
                                <option value="bottle">Bottle</option>
                                <option value="tin">Tin</option>
                                <option value="set">Set</option>
                                <option value="pair">Pair</option>
                            </select>
                        </div>
                        <div class="col mb-3">
                            <label class="form-label fw-semibold">
                                Low Stock Alert
                            </label>
                            <input asp-for="LowStockAlert" type="number"
                                   class="form-control" min="1" />
                        </div>
                    </div>

                    <div class="mb-4 form-check">
                        <input asp-for="IsActive" class="form-check-input"
                               type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">
                            Active (visible in sales)
                        </label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4">
                            Update
                        </button>
                        <a href="/Shop/Products"
                           class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>