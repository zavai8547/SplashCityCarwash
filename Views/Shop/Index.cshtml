@{
    ViewData["Title"] = "Shop & Inventory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">🏪 Shop & Inventory</h4>
    <a href="/Shop/NewSale" class="btn btn-success rounded-pill px-4">
        🛒 New Sale
    </a>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100"
             style="border-left:4px solid #10b981 !important;">
            <div class="card-body">
                <p class="text-muted small mb-1">Shop Revenue Today</p>
                <h3 class="fw-bold mb-0">
                    KES @ViewBag.RevenueToday.ToString("N0")
                </h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100"
             style="border-left:4px solid #3b82f6 !important;">
            <div class="card-body">
                <p class="text-muted small mb-1">Shop Profit Today</p>
                <h3 class="fw-bold mb-0">
                    KES @ViewBag.ProfitToday.ToString("N0")
                </h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100"
             style="border-left:4px solid #f59e0b !important;">
            <div class="card-body">
                <p class="text-muted small mb-1">Revenue This Month</p>
                <h3 class="fw-bold mb-0">
                    KES @ViewBag.RevenueMonth.ToString("N0")
                </h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100"
             style="border-left:4px solid @(ViewBag.LowStock > 0 ? "#ef4444" : "#10b981") !important;">
            <div class="card-body">
                <p class="text-muted small mb-1">Low Stock Alerts</p>
                <h3 class="fw-bold mb-0 @(ViewBag.LowStock > 0 ? "text-danger" : "")">
                    @ViewBag.LowStock products
                </h3>
            </div>
        </div>
    </div>
</div>

<!-- Quick Links -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <a href="/Shop/Products" class="card border-0 shadow-sm text-decoration-none">
            <div class="card-body text-center py-4">
                <div style="font-size:2.5rem;">📦</div>
                <h6 class="fw-bold mt-2 mb-0">Products</h6>
                <small class="text-muted">@ViewBag.TotalProducts active</small>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/Shop/StockIn" class="card border-0 shadow-sm text-decoration-none">
            <div class="card-body text-center py-4">
                <div style="font-size:2.5rem;">📥</div>
                <h6 class="fw-bold mt-2 mb-0">Stock In</h6>
                <small class="text-muted">Receive new stock</small>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/Shop/Sales" class="card border-0 shadow-sm text-decoration-none">
            <div class="card-body text-center py-4">
                <div style="font-size:2.5rem;">📋</div>
                <h6 class="fw-bold mt-2 mb-0">Sales History</h6>
                <small class="text-muted">View all shop sales</small>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/Shop/Reports" class="card border-0 shadow-sm text-decoration-none">
            <div class="card-body text-center py-4">
                <div style="font-size:2.5rem;">📊</div>
                <h6 class="fw-bold mt-2 mb-0">Shop Reports</h6>
                <small class="text-muted">Revenue & profit</small>
            </div>
        </a>
    </div>
</div>

<div class="row g-3">
    <!-- Recent Sales -->
    <div class="col-md-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-3">
                🛒 Recent Shop Sales
            </div>
            <div class="card-body p-0">
                @if (ViewBag.RecentSales == null ||
                     ((List<SplashCityCarwash.Models.ShopSale>)ViewBag.RecentSales).Count == 0)
                {
                    <div class="text-center text-muted py-4">
                        No sales yet
                    </div>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Time</th>
                                <th>Items</th>
                                <th>Total</th>
                                <th>Profit</th>
                                <th>Payment</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in (List<SplashCityCarwash.Models.ShopSale>)ViewBag.RecentSales)
                            {
                                <tr>
                                    <td>
                                        <small>@s.CreatedAt.ToString("dd MMM HH:mm")</small>
                                    </td>
                                    <td>
                                        <small>
                                            @string.Join(", ",
                                                s.Items.Select(i => i.Product.Name))
                                        </small>
                                    </td>
                                    <td class="fw-bold">
                                        KES @s.TotalAmount.ToString("N0")
                                    </td>
                                    <td class="text-success fw-bold">
                                        KES @s.TotalProfit.ToString("N0")
                                    </td>
                                    <td>
                                        <span class="badge bg-@(s.PaymentMethod == SplashCityCarwash.Models.PaymentMethod.Cash ? "success" : "warning text-dark")">
                                            @s.PaymentMethod
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <!-- Low Stock -->
    <div class="col-md-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-3 text-danger">
                ⚠️ Low Stock Alerts
            </div>
            <div class="card-body p-0">
                @if (ViewBag.LowStockProducts == null ||
                     ((List<SplashCityCarwash.Models.Product>)ViewBag.LowStockProducts).Count == 0)
                {
                    <div class="text-center text-muted py-4">
                        ✅ All stock levels are good
                    </div>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th>Stock</th>
                                <th>Alert At</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in (List<SplashCityCarwash.Models.Product>)ViewBag.LowStockProducts)
                            {
                                <tr>
                                    <td>@p.Name</td>
                                    <td>
                                        <span class="badge bg-danger">
                                            @p.CurrentStock @p.Unit
                                        </span>
                                    </td>
                                    <td class="text-muted small">≤@p.LowStockAlert</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>