@model IEnumerable<SplashCityCarwash.Models.Transaction>
@{
    ViewData["Title"] = "Transactions";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">🧾 Transactions</h4>
    <div class="d-flex gap-2">
        <span class="badge bg-success fs-6 d-flex align-items-center">
            KES @ViewBag.TotalRevenue.ToString("N0")
        </span>
        <a href="/Transactions/Export@(ViewBag.Status != null || ViewBag.Payment != null || ViewBag.Date != null ? "?status=" + ViewBag.Status + "&payment=" + ViewBag.Payment + "&date=" + ViewBag.Date : "")"
           class="btn btn-success rounded-pill px-3">
            ⬇️ Export CSV
        </a>
    </div>
</div>

<!-- Filters -->
<form method="get" class="card border-0 shadow-sm p-3 mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small text-muted">Status</label>
            <select name="status" class="form-select form-select-sm">
                <option value="">All Statuses</option>
                <option value="Waiting">Waiting</option>
                <option value="Washing">Washing</option>
                <option value="Completed">Completed</option>
                <option value="Paid">Paid ✅</option>
                <option value="Cancelled">Cancelled</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted">Payment</label>
            <select name="payment" class="form-select form-select-sm">
                <option value="">All Methods</option>
                <option value="Cash">Cash</option>
                <option value="MPesa">M-Pesa</option>
                <option value="Card">Card</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted">Date</label>
            <input type="date" name="date" value="@ViewBag.Date"
                   class="form-select form-select-sm" />
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-dark btn-sm">Filter</button>
            <a href="/Transactions/Index"
               class="btn btn-outline-secondary btn-sm">Clear</a>
        </div>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Vehicle</th>
                        <th>Services</th>
                        <th>Washed By</th>
                        <th>Amount</th>
                        <th>Payment</th>
                        <th>M-Pesa</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="11" class="text-center text-muted py-4">
                                No transactions found
                            </td>
                        </tr>
                    }
                    @foreach (var t in Model)
                    {
                        <tr>
                            <td><small>#@t.TransactionID</small></td>
                            <td>
                                <small>@t.CreatedAt.ToString("dd MMM HH:mm")</small>
                            </td>
                            <td>
                                <a href="/Customers/Details/@t.CustomerID"
                                   class="text-decoration-none fw-semibold">
                                    @t.Customer.FullName
                                </a>
                            </td>
                            <td>
                                <span class="badge bg-dark">
                                    @t.Vehicle.LicensePlate
                                </span>
                            </td>
                            <td>
                                <small>
                                    @string.Join(", ",
                                             t.TransactionServices
                                             .Select(s => s.Service.ServiceName))
                                </small>
                            </td>
                            <td>
                                <small>
                                    @(t.TransactionWashers.Any()
                                        ? string.Join(", ",
                                        t.TransactionWashers
                                        .Select(w => w.Washer.FullName))
                                        : "—")
                                </small>
                            </td>
                            <td class="fw-bold">
                                KES @t.TotalAmount.ToString("N0")
                            </td>
                            <td>
                                @{
                                    var pb = t.PaymentMethod ==
                                    SplashCityCarwash.Models.PaymentMethod.Cash
                                    ? "success"
                                    : t.PaymentMethod ==
                                    SplashCityCarwash.Models.PaymentMethod.MPesa
                                    ? "warning text-dark" : "primary";
                                }
                                <span class="badge bg-@pb">@t.PaymentMethod</span>
                            </td>
                            <td>
                                <small class="text-muted">
                                    @(t.MpesaCode ?? "—")
                                </small>
                            </td>
                            <td>
                                @{
                                    var sb = t.Status ==
                                    SplashCityCarwash.Models.WashStatus.Paid
                                    ? "success"
                                    : t.Status ==
                                    SplashCityCarwash.Models.WashStatus.Completed
                                    ? "info"
                                    : t.Status ==
                                    SplashCityCarwash.Models.WashStatus.Washing
                                    ? "primary"
                                    : t.Status ==
                                    SplashCityCarwash.Models.WashStatus.Cancelled
                                    ? "danger" : "warning text-dark";
                                }
                                <span class="badge bg-@sb">@t.Status</span>
                            </td>
                            <td>
                                <a href="/Transactions/Details/@t.TransactionID"
                                   class="btn btn-sm btn-outline-primary">View</a>
                                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                {
                                    <a href="/Transactions/Edit/@t.TransactionID"
                                       class="btn btn-sm btn-outline-secondary">Edit</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>