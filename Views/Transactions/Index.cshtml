@model IEnumerable<SplashCityCarwash.Models.Transaction>
@{
    ViewData["Title"] = "Transactions";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">🧾 Transaction History</h4>
    <div class="badge bg-success fs-6">
        Revenue: KES @ViewBag.TotalRevenue.ToString("N0")
    </div>
</div>

<!-- Filters -->
<form method="get" class="card border-0 shadow-sm p-3 mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small text-muted">Status</label>
            <select name="status" class="form-select form-select-sm">
                <option value="">All Statuses</option>
                <option value="Waiting">Waiting</option>
                <option value="Washing">Washing</option>
                <option value="Completed">Completed</option>
                <option value="Cancelled">Cancelled</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted">Payment</label>
            <select name="payment" class="form-select form-select-sm">
                <option value="">All Methods</option>
                <option value="Cash">Cash</option>
                <option value="MPesa">M-Pesa</option>
                <option value="Card">Card</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted">Date</label>
            <input type="date" name="date" value="@ViewBag.Date"
                   class="form-select form-select-sm" />
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-dark btn-sm">Filter</button>
            <a href="/Transactions/Index" class="btn btn-outline-secondary btn-sm">
                Clear
            </a>
        </div>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Customer</th>
                    <th>Vehicle</th>
                    <th>Services</th>
                    <th>Amount</th>
                    <th>Payment</th>
                    <th>Status</th>
                    <th>Time</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            No transactions found
                        </td>
                    </tr>
                }
                @foreach (var t in Model)
                {
                    <tr>
                        <td><small>#@t.TransactionID</small></td>
                        <td>
                            <a href="/Customers/Details/@t.CustomerID"
                               class="text-decoration-none fw-semibold">
                                @t.Customer.FullName
                            </a><br />
                            <small class="text-muted">@t.Customer.Phone</small>
                        </td>
                        <td>
                            <span class="badge bg-dark">
                                @t.Vehicle.LicensePlate
                            </span>
                        </td>
                        <td>
                            <small>
                                @string.Join(", ",
                                         t.TransactionServices.Select(s => s.Service.ServiceName))
                            </small>
                        </td>
                        <td class="fw-bold">KES @t.TotalAmount.ToString("N0")</td>
                        <td>
                            @{
                                var payBadge = t.PaymentMethod ==
                                SplashCityCarwash.Models.PaymentMethod.Cash
                                ? "success"
                                : t.PaymentMethod ==
                                SplashCityCarwash.Models.PaymentMethod.MPesa
                                ? "warning text-dark" : "primary";
                            }
                            <span class="badge bg-@payBadge">
                                @t.PaymentMethod
                            </span>
                        </td>
                        <td>
                            @{
                                var statusBadge = t.Status ==
                                SplashCityCarwash.Models.WashStatus.Completed
                                ? "success"
                                : t.Status ==
                                SplashCityCarwash.Models.WashStatus.Washing
                                ? "primary"
                                : t.Status ==
                                SplashCityCarwash.Models.WashStatus.Cancelled
                                ? "danger" : "warning text-dark";
                            }
                            <span class="badge bg-@statusBadge">@t.Status</span>
                        </td>
                        <td>
                            <small class="text-muted">
                                @t.CreatedAt.ToString("dd MMM HH:mm")
                            </small>
                        </td>
                        <td>
                            <a href="/Transactions/Details/@t.TransactionID"
                               class="btn btn-sm btn-outline-primary">
                                View
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
