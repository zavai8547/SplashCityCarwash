@model SplashCityCarwash.Models.EditTransactionViewModel
@{
    ViewData["Title"] = "Edit Transaction";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">✏️ Edit Transaction #@Model.TransactionID</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="TransactionID" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Date</label>
                        <input asp-for="WashDate" type="date"
                               class="form-control"
                               max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Time</label>
                        <input asp-for="WashTime" type="time" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Total Amount (KES)
                        </label>
                        <input asp-for="TotalAmount" type="number"
                               class="form-control" step="0.01" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Payment Method</label>
                        <select asp-for="PaymentMethod" class="form-select">
                            <option value="0">💵 Cash</option>
                            <option value="1">📱 M-Pesa</option>
                            <option value="2">💳 Card</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            M-Pesa Code
                        </label>
                        <input asp-for="MpesaCode"
                               class="form-control text-uppercase"
                               placeholder="e.g. QHX4RT8K2P" />
                        <small class="text-muted">Leave blank if Cash or Card</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Status</label>
                        <select asp-for="Status" class="form-select">
                            <option value="0">⏳ Waiting</option>
                            <option value="1">🚿 Washing</option>
                            <option value="2">✅ Completed</option>
                            <option value="3">❌ Cancelled</option>
                            <option value="4">💰 Paid</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Notes</label>
                        <textarea asp-for="Notes" class="form-control"
                                  rows="3"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4">
                            Save Changes
                        </button>
                        <a href="/Transactions/Details/@Model.TransactionID"
                           class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>