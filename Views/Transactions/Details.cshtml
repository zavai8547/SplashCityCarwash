@model SplashCityCarwash.Models.Transaction
@{
    ViewData["Title"] = "Transaction Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">🧾 Transaction #@Model.TransactionID</h4>
    <a href="/Transactions/Index" class="btn btn-outline-dark">← Back</a>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white fw-semibold border-0 pt-3">
                Services
            </div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Service</th>
                            <th class="text-end">Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ts in Model.TransactionServices)
                        {
                            <tr>
                                <td>@ts.Service.ServiceName</td>
                                <td class="text-end">
                                    KES @ts.PriceAtTime.ToString("N0")
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-dark">
                            <th>Total</th>
                            <th class="text-end">
                                KES @Model.TotalAmount.ToString("N0")
                            </th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <strong>Notes:</strong> @Model.Notes
                </div>
            </div>
        }
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="text-muted mb-3">Customer</h6>
                <p class="mb-1 fw-semibold">@Model.Customer.FullName</p>
                <p class="mb-1">📞 @Model.Customer.Phone</p>
                <p class="mb-0">
                    🚗
                    <span class="badge bg-dark">@Model.Vehicle.LicensePlate</span>
                </p>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="text-muted mb-3">Payment</h6>
                <p class="mb-1">
                    <strong>Method:</strong>
                    <span class="badge bg-success">@Model.PaymentMethod</span>
                </p>
                <p class="mb-1">
                    <strong>Status:</strong>
                    <span class="badge bg-@(Model.Status == WashStatus.Completed ?
                        "success" : Model.Status == WashStatus.Washing ?
                        "primary" : "warning text-dark")">
                        @Model.Status
                    </span>
                </p>
                <p class="mb-1">
                    <strong>Staff:</strong> @Model.Staff.FullName
                </p>
                <p class="mb-0">
                    <strong>Time:</strong>
                    @Model.CreatedAt.ToString("dd MMM yyyy HH:mm")
                </p>
            </div>
        </div>

        <div class="card border-0 shadow-sm bg-success text-white">
            <div class="card-body text-center">
                <p class="mb-1 opacity-75">Total Paid</p>
                <h2 class="fw-bold">KES @Model.TotalAmount.ToString("N0")</h2>
            </div>
        </div>
    </div>
</div>