@model SplashCityCarwash.Models.Transaction
@{
    ViewData["Title"] = "Transaction Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">🧾 Transaction #@Model.TransactionID</h4>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <a href="/Transactions/Edit/@Model.TransactionID"
               class="btn btn-outline-secondary">✏️ Edit</a>
        }
        <a href="/Transactions/Index" class="btn btn-outline-dark">← Back</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-8">

        <!-- Services -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white fw-semibold border-0 pt-3">
                Services
            </div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Service</th>
                            <th class="text-end">Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ts in Model.TransactionServices)
                        {
                            <tr>
                                <td>@ts.Service.ServiceName</td>
                                <td class="text-end">
                                    KES @ts.PriceAtTime.ToString("N0")
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-dark">
                            <th>Total</th>
                            <th class="text-end">
                                KES @Model.TotalAmount.ToString("N0")
                            </th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <!-- Washers -->
        @if (Model.TransactionWashers.Any())
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-semibold mb-2">🧑‍🔧 Washed By</h6>
                    @foreach (var tw in Model.TransactionWashers)
                    {
                        <span class="badge bg-primary me-2 mb-1 fs-6">
                            👤 @tw.Washer.FullName
                        </span>
                    }
                </div>
            </div>
        }

        <!-- Mark as Paid -->
        @if (Model.Status == SplashCityCarwash.Models.WashStatus.Completed)
        {
            <div class="card border-0 shadow-sm border-start border-4 border-success mb-3">
                <div class="card-body">
                    <h6 class="fw-bold text-success mb-3">💰 Confirm Payment</h6>
                    <p class="text-muted small mb-3">
                        Wash complete. Collect payment and confirm below.
                    </p>
                    <form asp-action="MarkPaid" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.TransactionID" />
                        @if (Model.PaymentMethod ==
                       SplashCityCarwash.Models.PaymentMethod.MPesa)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">
                                    📱 M-Pesa Code
                                </label>
                                <input name="mpesaCode"
                                       class="form-control text-uppercase"
                                       placeholder="e.g. QHX4RT8K2P"
                                       value="@Model.MpesaCode" />
                            </div>
                        }
                        <button type="submit" class="btn btn-success px-4">
                            ✅ Confirm Payment Received
                        </button>
                    </form>
                </div>
            </div>
        }

        @if (Model.Status == SplashCityCarwash.Models.WashStatus.Paid)
        {
            <div class="card border-0 shadow-sm bg-success text-white mb-3">
                <div class="card-body">
                    <h6 class="mb-1">✅ Payment Confirmed</h6>
                    <p class="mb-0 small opacity-75">
                        @(Model.PaidAt?.ToString("dd MMM yyyy HH:mm") ?? "—")
                    </p>
                    @if (!string.IsNullOrEmpty(Model.MpesaCode))
                    {
                        <p class="mb-0 mt-1">
                            📱 M-Pesa: <strong>@Model.MpesaCode</strong>
                        </p>
                    }
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <strong>📝 Notes:</strong> @Model.Notes
                </div>
            </div>
        }
    </div>

    <div class="col-md-4">

        <!-- Customer & Vehicle -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="text-muted mb-3">Customer & Vehicle</h6>
                <p class="mb-1 fw-semibold">@Model.Customer.FullName</p>
                <p class="mb-1">📞 @Model.Customer.Phone</p>
                <p class="mb-2">
                    🚗 <span class="badge bg-dark">@Model.Vehicle.LicensePlate</span>
                </p>
                @{
                    var cm = $"{Model.Vehicle.Make} {Model.Vehicle.CarModel}".Trim();
                }
                @if (!string.IsNullOrEmpty(cm))
                {
                    <p class="mb-0 text-muted small">@cm</p>
                }
            </div>
        </div>

        <!-- Payment Info -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="text-muted mb-3">Payment Info</h6>
                <p class="mb-1">
                    <strong>Method:</strong>
                    @{
                        var pb = Model.PaymentMethod ==
                        SplashCityCarwash.Models.PaymentMethod.Cash
                        ? "success"
                        : Model.PaymentMethod ==
                        SplashCityCarwash.Models.PaymentMethod.MPesa
                        ? "warning text-dark" : "primary";
                    }
                    <span class="badge bg-@pb">@Model.PaymentMethod</span>
                </p>
                @if (!string.IsNullOrEmpty(Model.MpesaCode))
                {
                    <p class="mb-1">
                        <strong>M-Pesa Code:</strong>
                        <span class="badge bg-success">@Model.MpesaCode</span>
                    </p>
                }
                <p class="mb-1">
                    <strong>Status:</strong>
                    @{
                        var sb = Model.Status ==
                        SplashCityCarwash.Models.WashStatus.Paid ? "success"
                        : Model.Status ==
                        SplashCityCarwash.Models.WashStatus.Completed ? "info"
                        : Model.Status ==
                        SplashCityCarwash.Models.WashStatus.Washing ? "primary"
                        : Model.Status ==
                        SplashCityCarwash.Models.WashStatus.Cancelled ? "danger"
                        : "warning text-dark";
                    }
                    <span class="badge bg-@sb">@Model.Status</span>
                </p>
                <p class="mb-1">
                    <strong>Cashier:</strong> @Model.Staff.FullName
                </p>
                <p class="mb-0">
                    <strong>Date:</strong>
                    @Model.CreatedAt.ToString("dd MMM yyyy HH:mm")
                </p>
            </div>
        </div>

        <!-- Total -->
        <div class="card border-0 shadow-sm bg-dark text-white">
            <div class="card-body text-center">
                <p class="mb-1 opacity-75">Total Amount</p>
                <h2 class="fw-bold">KES @Model.TotalAmount.ToString("N0")</h2>
            </div>
        </div>
    </div>
</div>