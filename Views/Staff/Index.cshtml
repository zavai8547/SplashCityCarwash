@model IEnumerable<SplashCityCarwash.Models.StaffViewModel>
@{
    ViewData["Title"] = "Staff";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">👤 Staff Management</h4>
    @if (User.IsInRole("Admin"))
    {
        <a href="/Auth/Register" class="btn btn-success rounded-pill px-4">+ Add Staff</a>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td class="fw-semibold">@s.User.FullName</td>
                        <td>@s.User.Email</td>
                        <td>@(s.User.Phone ?? "—")</td>
                        <td>
                            <span class="badge bg-@(s.Role == "Admin" ? "danger" :
                                s.Role == "Manager" ? "warning text-dark" :
                                s.Role == "Cashier" ? "primary" : "secondary")">
                                @s.Role
                            </span>
                        </td>
                        <td>
                            @if (s.User.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>
                        <td>
                            <small>@s.User.CreatedAt.ToString("dd MMM yyyy")</small>
                        </td>
                        <td>
                            @if (User.IsInRole("Admin"))
                            {
                                <form asp-action="ToggleActive" method="post"
                                      style="display:inline">
                                    <input type="hidden" name="id" value="@s.User.Id" />
                                    <button type="submit"
                                            class="btn btn-sm @(s.User.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                        @(s.User.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </form>

                                <form asp-action="ChangeRole" method="post"
                                      style="display:inline">
                                    <input type="hidden" name="id" value="@s.User.Id" />
                                    <select name="newRole"
                                            class="form-select form-select-sm d-inline w-auto"
                                            onchange="this.form.submit()">
                                        <option value="" selected disabled>Role...</option>
                                        <option value="Admin">Admin</option>
                                        <option value="Manager">Manager</option>
                                        <option value="Cashier">Cashier</option>
                                        <option value="Washer">Washer</option>
                                    </select>
                                </form>

                                @if (s.User.Email != User.Identity!.Name)
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-outline-warning"
                                            data-bs-toggle="modal"
                                            data-bs-target="#resetModal_@s.User.Id">
                                        🔑 Reset
                                    </button>

                                    <div class="modal fade" id="resetModal_@s.User.Id"
                                         tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content">
                                                <div class="modal-header bg-dark text-white">
                                                    <h5 class="modal-title">
                                                        🔑 Reset Password — @s.User.FullName
                                                    </h5>
                                                    <button type="button" class="btn-close btn-close-white"
                                                            data-bs-dismiss="modal"></button>
                                                </div>
                                                <form method="post" action="/Staff/ResetPassword">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@s.User.Id" />
                                                    <div class="modal-body">
                                                        <p class="text-muted small mb-3">
                                                            Enter a temporary password for
                                                            <strong>@s.User.FullName</strong>.
                                                            Tell them this password privately — they should
                                                            change it after logging in.
                                                        </p>
                                                        <div class="mb-3 text-start">
                                                            <label class="form-label fw-semibold">
                                                                New Temporary Password
                                                            </label>
                                                            <div class="input-group">
                                                                <input type="password"
                                                                       name="newPassword"
                                                                       class="form-control"
                                                                       id="pw_@s.User.Id"
                                                                       placeholder="Min 6 characters"
                                                                       required />
                                                                <button type="button"
                                                                        class="btn btn-outline-secondary"
                                                                        onclick="toggleResetPw('@s.User.Id')">
                                                                    👁️
                                                                </button>
                                                            </div>
                                                            <small class="text-muted">
                                                                Example: Temp@123
                                                            </small>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button"
                                                                class="btn btn-outline-secondary"
                                                                data-bs-dismiss="modal">
                                                            Cancel
                                                        </button>
                                                        <button type="submit" class="btn btn-warning">
                                                            🔑 Reset Password
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function toggleResetPw(userId) {
        const field = document.getElementById('pw_' + userId);
        const isPassword = field.type === 'password';
        field.type = isPassword ? 'text' : 'password';
    }
</script>