<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kujaributuu — @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: #E3F2FD;
        }

        .sidebar {
            width: 220px;
            height: 100vh;
            background: linear-gradient(180deg, #1565C0, #0D47A1);
            position: fixed;
            top: 0;
            left: 0;
            z-index: 100;
            transition: transform 0.3s ease;
            overflow-y: auto;
            overflow-x: hidden;
        }

            /* Scrollbar styling */
            .sidebar::-webkit-scrollbar {
                width: 4px;
            }

            .sidebar::-webkit-scrollbar-track {
                background: rgba(0,0,0,0.1);
            }

            .sidebar::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,0.3);
                border-radius: 4px;
            }

                .sidebar::-webkit-scrollbar-thumb:hover {
                    background: rgba(255,255,255,0.6);
                }

            .sidebar .brand {
                padding: 16px 20px;
                color: white;
                font-weight: 700;
                font-size: 15px;
                border-bottom: 1px solid rgba(255,255,255,0.2);
                line-height: 1.3;
            }

                .sidebar .brand span {
                    color: #FFD600;
                    font-size: 13px;
                    display: block;
                    font-weight: 400;
                }

            .sidebar .nav-link {
                color: rgba(255,255,255,0.8);
                padding: 8px 20px;
                font-size: 13px;
                border-radius: 0;
                transition: all 0.2s;
            }

                .sidebar .nav-link:hover, .sidebar .nav-link.active {
                    color: #FFD600;
                    background: rgba(255,255,255,0.1);
                    padding-left: 28px;
                }

            .sidebar .nav-section {
                color: rgba(255,255,255,0.4);
                font-size: 11px;
                padding: 14px 20px 4px;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

        .main-content {
            margin-left: 220px;
            padding: 24px;
        }

        .topbar {
            background: white;
            padding: 12px 24px;
            margin-left: 220px;
            border-bottom: 3px solid #1565C0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 99;
        }

        /* MOBILE HAMBURGER */
        .hamburger {
            display: none;
            position: fixed;
            top: 12px;
            left: 12px;
            z-index: 200;
            background: #1565C0;
            border: none;
            border-radius: 8px;
            padding: 8px 12px;
            color: white;
            font-size: 20px;
        }

        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 99;
        }

        /* TOAST */
        .toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
        }

        .toast {
            min-width: 300px;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        }

        .toast-success {
            border-left: 4px solid #10b981;
        }

        .toast-error {
            border-left: 4px solid #ef4444;
        }

        /* RESPONSIVE (UPDATED) */
        @@media (max-width: 1024px) {
            .hamburger {
                display: block;
            }

            .sidebar {
                transform: translateX(-100%);
                z-index: 150;
            }

                .sidebar.open {
                    transform: translateX(0);
                }

            .sidebar-overlay.open {
                display: block;
            }

            .main-content {
                margin-left: 0;
                padding: 16px;
            }

            .topbar {
                margin-left: 0;
                padding-left: 56px;
            }

            .table-responsive {
                overflow-x: auto;
            }

            h4 {
                font-size: 1.1rem;
            }
        }
    </style>
</head>
<body>

    <!-- MOBILE HAMBURGER -->
    <button class="hamburger" onclick="toggleSidebar()">☰</button>
    <div class="sidebar-overlay" id="overlay" onclick="toggleSidebar()"></div>

    <!-- TOAST NOTIFICATIONS -->
    <div class="toast-container">
        @if (TempData["Success"] != null)
        {
            <div class="toast toast-success align-items-center show mb-2" role="alert">
                <div class="d-flex">
                    <div class="toast-body d-flex align-items-center gap-2">
                        <span style="color:#10b981;">✅</span>
                        <span>@TempData["Success"]</span>
                    </div>
                    <button type="button" class="btn-close me-2 m-auto"
                            data-bs-dismiss="toast"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="toast toast-error align-items-center show mb-2" role="alert">
                <div class="d-flex">
                    <div class="toast-body d-flex align-items-center gap-2">
                        <span style="color:#ef4444;">❌</span>
                        <span>@TempData["Error"]</span>
                    </div>
                    <button type="button" class="btn-close me-2 m-auto"
                            data-bs-dismiss="toast"></button>
                </div>
            </div>
        }
    </div>

    <!-- SIDEBAR -->
    <div class="sidebar" id="sidebar">
        <div class="brand">
            Kujaributuu
            <span>Carwash & Detailing</span>
        </div>
        <nav class="nav flex-column mt-2">
            <span class="nav-section">Main</span>
            <a class="nav-link @(ViewData["Title"]?.ToString() == "Dashboard" ? "active" : "")"
               href="/Dashboard/Index">📊 Dashboard</a>

            <span class="nav-section">Operations</span>
            <a class="nav-link" href="/Wash/New">🚗 New Wash</a>
            <a class="nav-link" href="/Queue/Index">🚦 Queue</a>
            <a class="nav-link" href="/Transactions/Index">🧾 Transactions</a>

            <span class="nav-section">Management</span>
            <a class="nav-link" href="/Customers/Index">👥 Customers</a>
            <a class="nav-link" href="/Vehicles/Index">🚙 Vehicles</a>

            <span class="nav-section">Admin</span>
            <a class="nav-link" href="/Services/Index">💼 Services</a>
            <a class="nav-link" href="/Staff/Index">👤 Staff</a>
            <a class="nav-link" href="/Reports/Index">📈 Reports</a>
            <a class="nav-link" href="/Expenses/Index">💰 Expenses</a>
            <a class="nav-link" href="/Shop/Index">🏪 Shop & Inventory</a>
        </nav>
    </div>

    <!-- rest unchanged -->

    <!-- TOPBAR -->
    <div class="topbar">
        <h6 class="mb-0 fw-semibold" style="color:#1565C0;">
            @ViewData["Title"]
        </h6>
        <div class="d-flex align-items-center gap-3">
            <span class="text-muted small d-none d-md-inline">
                👤 @User.Identity!.Name
            </span>
            <form asp-controller="Auth" asp-action="Logout" method="post">
                <button type="submit" class="btn btn-sm btn-outline-danger">
                    Logout
                </button>
            </form>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('overlay').classList.toggle('open');
        }

        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.toast').forEach(function (toast) {
                setTimeout(function () {
                    toast.classList.remove('show');
                    setTimeout(() => toast.remove(), 300);
                }, 4000);
            });
        });
    </script>
</body>
</html>