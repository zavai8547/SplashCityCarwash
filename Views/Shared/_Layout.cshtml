<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Splash City — @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body {
            background: #f8fafc;
        }

        .sidebar {
            width: 240px;
            min-height: 100vh;
            background: #1a1a2e;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 100;
        }

            .sidebar .brand {
                padding: 20px;
                color: white;
                font-weight: 700;
                font-size: 18px;
                border-bottom: 1px solid rgba(255,255,255,0.1);
            }

            .sidebar .nav-link {
                color: rgba(255,255,255,0.7);
                padding: 10px 20px;
                font-size: 14px;
                border-radius: 0;
                transition: all 0.2s;
            }

                .sidebar .nav-link:hover, .sidebar .nav-link.active {
                    color: white;
                    background: rgba(255,255,255,0.1);
                    padding-left: 28px;
                }

            .sidebar .nav-section {
                color: rgba(255,255,255,0.3);
                font-size: 11px;
                padding: 16px 20px 6px;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

        .main-content {
            margin-left: 240px;
            padding: 30px;
        }

        .topbar {
            background: white;
            padding: 12px 30px;
            margin-left: 240px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 99;
        }

        /* TOAST */
        .toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
        }

        .toast {
            min-width: 300px;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        }

        .toast-success {
            border-left: 4px solid #10b981;
        }

        .toast-error {
            border-left: 4px solid #ef4444;
        }

        .toast-info {
            border-left: 4px solid #3b82f6;
        }
    </style>
</head>
<body>

    <!-- TOAST CONTAINER -->
    <div class="toast-container">
        @if (TempData["Success"] != null)
        {
            <div class="toast toast-success align-items-center show mb-2" role="alert">
                <div class="d-flex">
                    <div class="toast-body d-flex align-items-center gap-2">
                        <span style="color:#10b981; font-size:1.2rem;">✅</span>
                        <span>@TempData["Success"]</span>
                    </div>
                    <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="toast toast-error align-items-center show mb-2" role="alert">
                <div class="d-flex">
                    <div class="toast-body d-flex align-items-center gap-2">
                        <span style="color:#ef4444; font-size:1.2rem;">❌</span>
                        <span>@TempData["Error"]</span>
                    </div>
                    <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        }
        @if (TempData["Info"] != null)
        {
            <div class="toast toast-info align-items-center show mb-2" role="alert">
                <div class="d-flex">
                    <div class="toast-body d-flex align-items-center gap-2">
                        <span style="color:#3b82f6; font-size:1.2rem;">ℹ️</span>
                        <span>@TempData["Info"]</span>
                    </div>
                    <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        }
    </div>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="brand">🚗 Splash City</div>
        <nav class="nav flex-column mt-2">

            <span class="nav-section">Main</span>
            <a class="nav-link @(ViewData["Title"]?.ToString() == "Dashboard" ? "active" : "")"
               href="/Dashboard/Index">📊 Dashboard</a>

            <span class="nav-section">Operations</span>
            <a class="nav-link" href="/Wash/New">🚗 New Wash</a>
            <a class="nav-link" href="/Queue/Index">🚦 Queue</a>
            <a class="nav-link" href="/Transactions/Index">🧾 Transactions</a>

            <span class="nav-section">Management</span>
            <a class="nav-link" href="/Customers/Index">👥 Customers</a>
            <a class="nav-link" href="/Vehicles/Index">🚙 Vehicles</a>

            <span class="nav-section">Admin</span>
            <a class="nav-link" href="/Services/Index">💼 Services</a>
            <a class="nav-link" href="/Staff/Index">👤 Staff</a>
            <a class="nav-link" href="/Reports/Index">📈 Reports</a>
            <a class="nav-link" href="/Expenses/Index">💰 Expenses</a>
            <a class="nav-link" href="/Settings/Index">⚙️ Settings</a>

        </nav>
    </div>

    <!-- TOPBAR -->
    <div class="topbar">
        <h6 class="mb-0 fw-semibold">@ViewData["Title"]</h6>
        <div class="d-flex align-items-center gap-3">
            <span class="text-muted small">👤 @User.Identity!.Name</span>
            <form asp-controller="Auth" asp-action="Logout" method="post">
                <button type="submit" class="btn btn-sm btn-outline-danger">Logout</button>
            </form>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Auto-dismiss toasts after 4 seconds
        document.addEventListener('DOMContentLoaded', function () {
            var toasts = document.querySelectorAll('.toast');
            toasts.forEach(function (toast) {
                setTimeout(function () {
                    toast.classList.remove('show');
                    setTimeout(() => toast.remove(), 300);
                }, 4000);
            });
        });
    </script>
</body>
</html>