@model IEnumerable<SplashCityCarwash.Models.ServicePackage>
@{
    ViewData["Title"] = "Services";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">💼 Service Packages</h4>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <a href="/Services/Create" class="btn btn-success rounded-pill px-4">+ Add Service</a>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Service Name</th>
                    <th>Description</th>
                    <th>Price (KES)</th>
                    <th>Duration</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td class="fw-semibold">@s.ServiceName</td>
                        <td><small class="text-muted">@s.Description</small></td>
                        <td>KES @s.Price.ToString("N0")</td>
                        <td>@s.EstimatedDuration mins</td>
                        <td>
                            @if (s.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td>
                            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                            {
                                <a href="/Services/Edit/@s.ServiceID"
                                   class="btn btn-sm btn-outline-secondary">Edit</a>
                                <form asp-action="ToggleActive" method="post"
                                      style="display:inline">
                                    <input type="hidden" name="id" value="@s.ServiceID" />
                                    <button type="submit"
                                            class="btn btn-sm @(s.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                        @(s.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>