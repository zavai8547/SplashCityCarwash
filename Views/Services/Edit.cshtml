@model SplashCityCarwash.Models.ServicePackage
@{
    ViewData["Title"] = "Edit Service";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">✏️ Edit Service</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="ServiceID" />
                    <div class="mb-3">
                        <label asp-for="ServiceName" class="form-label fw-semibold">Service Name *</label>
                        <input asp-for="ServiceName" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Price" class="form-label fw-semibold">Price (KES) *</label>
                        <input asp-for="Price" class="form-control" type="number" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="EstimatedDuration" class="form-label fw-semibold">Duration (minutes)</label>
                        <input asp-for="EstimatedDuration" class="form-control" type="number" />
                    </div>
                    <div class="mb-4 form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">Active</label>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4">Update</button>
                        <a href="/Services/Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>