@model SplashCityCarwash.Models.ServicePackage
@{
    ViewData["Title"] = "Add Service";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">➕ Add Service Package</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label asp-for="ServiceName" class="form-label fw-semibold">Service Name *</label>
                        <input asp-for="ServiceName" class="form-control" placeholder="e.g. Full Detail" />
                        <span asp-validation-for="ServiceName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Price" class="form-label fw-semibold">Price (KES) *</label>
                        <input asp-for="Price" class="form-control" type="number" placeholder="500" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="EstimatedDuration" class="form-label fw-semibold">Duration (minutes)</label>
                        <input asp-for="EstimatedDuration" class="form-control" type="number" placeholder="30" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4">Save Service</button>
                        <a href="/Services/Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>