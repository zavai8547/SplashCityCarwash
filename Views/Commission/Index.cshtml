@model List<SplashCityCarwash.Models.WasherCommissionSummary>
@{
    ViewData["Title"] = "My Earnings";
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool isManager = ViewBag.IsManager;
    string period = ViewBag.Period;
    var records = ViewBag.Records as
        List<SplashCityCarwash.Models.TransactionWasher>;
    string currentUserID = ViewBag.CurrentUserID;
    decimal rate = ViewBag.CommissionRate;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        💰 @(isManager ? "Commission Overview" : "My Earnings")
    </h4>
    <div class="badge bg-dark fs-6">@rate% Commission Rate</div>
</div>

<!-- Period Filter -->
<div class="d-flex gap-2 mb-4 flex-wrap">
    <a href="/Commission/Index?period=today"
       class="btn @(period == "today" ? "btn-dark" : "btn-outline-secondary") rounded-pill px-4">
        Today
    </a>
    <a href="/Commission/Index?period=week"
       class="btn @(period == "week" ? "btn-dark" : "btn-outline-secondary") rounded-pill px-4">
        This Week
    </a>
    <a href="/Commission/Index?period=month"
       class="btn @(period == "month" ? "btn-dark" : "btn-outline-secondary") rounded-pill px-4">
        This Month
    </a>
</div>

<!-- Period Label -->
<div class="mb-3">
    <small class="text-muted">
        📅 @ViewBag.StartDate.ToString("dd MMM yyyy")
        @if (ViewBag.StartDate != ViewBag.EndDate)
        {
            <span> — @ViewBag.EndDate.ToString("dd MMM yyyy")</span>
        }
    </small>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center text-muted py-5">
            <div style="font-size:3rem;">🧹</div>
            <h5 class="mt-3">No washes recorded for this period</h5>
            <p class="mb-0">Completed washes will appear here.</p>
        </div>
    </div>
}
else
{
    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        @foreach (var w in Model)
        {
            var isMe = w.WasherID == currentUserID;
            <div class="col-md-@(isManager ? "4" : "12")">
                <div class="card border-0 shadow-sm h-100"
                     style="border-left: 5px solid @(isMe ? "#FFD600" : "#1565C0") !important;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h6 class="fw-bold mb-0">
                                    @w.WasherName
                                    @if (isMe)
                                    {
                                        <span class="badge bg-warning text-dark ms-1">
                                            You
                                        </span>
                                    }
                                </h6>
                                <small class="text-muted">
                                    @w.TotalWashes wash@(w.TotalWashes != 1 ? "es" : "")
                                </small>
                            </div>
                            <div class="text-end">
                                <div class="text-muted small">Total wash value</div>
                                <div class="fw-bold">
                                    KES @w.TotalWashValue.ToString("N0")
                                </div>
                            </div>
                        </div>

                        <div class="p-3 rounded text-center"
                             style="background: @(isMe ? "#FFF9C4" : "#F0FDF4");">
                            <div class="text-muted small mb-1">
                                Commission Earned (@rate%)
                            </div>
                            <h3 class="fw-bold mb-0"
                                style="color: @(isMe ? "#B8860B" : "#10b981");">
                                KES @w.Commission.ToString("N0")
                            </h3>
                        </div>

                        @if (!isManager || isMe)
                        {
                            <div class="mt-3 text-center">
                                <small class="text-muted">
                                    Average per wash:
                                    <strong>
                                        KES @((w.TotalWashes > 0
                                        ? w.Commission / w.TotalWashes
                                        : 0).ToString("N0"))
                                    </strong>
                                </small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @if (isManager)
    {
        <!-- Manager Total Summary -->
        <div class="card border-0 shadow-sm bg-dark text-white mb-4">
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-md-4">
                        <p class="mb-1 opacity-75 small">Total Washes</p>
                        <h4 class="fw-bold">@Model.Sum(w => w.TotalWashes)</h4>
                    </div>
                    <div class="col-md-4">
                        <p class="mb-1 opacity-75 small">Total Wash Revenue</p>
                        <h4 class="fw-bold">
                            KES @Model.Sum(w => w.TotalWashValue).ToString("N0")
                        </h4>
                    </div>
                    <div class="col-md-4">
                        <p class="mb-1 opacity-75 small">
                            Total Commission to Pay
                        </p>
                        <h4 class="fw-bold text-warning">
                            KES @Model.Sum(w => w.Commission).ToString("N0")
                        </h4>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Individual Wash Breakdown -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white fw-semibold border-0 pt-3">
            🔍 Wash Breakdown
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Date</th>
                            @if (isManager)
                            {
                                <th>Washer</th>
                            }
                            <th>Vehicle</th>
                            <th>Services</th>
                            <th>Wash Value</th>
                            <th>Commission (@rate%)</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in records!
                       .Where(r => !isManager ||
                       true)
                       .OrderByDescending(r => r.Transaction.CreatedAt))
                        {
                            var commission = r.Transaction.TotalAmount * (rate / 100);
                            <tr>
                                <td>
                                    <small>
                                        @(r.Transaction.CreatedAt.ToString("dd MMM yyyy HH:mm"))
                                    </small>
                                </td>
                                @if (isManager)
                                {
                                    <td>
                                        <span class="badge bg-primary">
                                            @r.Washer.FullName
                                        </span>
                                    </td>
                                }
                                <td>
                                    <span class="badge bg-dark">
                                        @r.Transaction.Vehicle?.LicensePlate
                                    </span>
                                </td>
                                <td>
                                    <small>
                                        @string.Join(", ",
                                                 r.Transaction.TransactionServices
                                                 .Select(s => s.Service.ServiceName))
                                    </small>
                                </td>
                                <td class="fw-bold">
                                    KES @r.Transaction.TotalAmount.ToString("N0")
                                </td>
                                <td>
                                    <span class="text-success fw-bold">
                                        KES @commission.ToString("N0")
                                    </span>
                                </td>
                                <td>
                                    @{
                                        var badge = r.Transaction.Status ==
                                        WashStatus.Paid ? "success"
                                        : r.Transaction.Status ==
                                        WashStatus.Completed ? "info"
                                        : "warning text-dark";
                                    }
                                    <span class="badge bg-@badge">
                                        @r.Transaction.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}