@model IEnumerable<SplashCityCarwash.Models.WashQueue>
@{
    ViewData["Title"] = "Queue";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">🚦 Live Wash Queue</h4>
    <a href="/Wash/New" class="btn btn-success rounded-pill px-4">
        + New Wash
    </a>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <div style="font-size:4rem;">🎉</div>
            <h5 class="text-muted">Queue is empty!</h5>
            <p class="text-muted">No active washes right now.</p>
            <a href="/Wash/New" class="btn btn-success rounded-pill px-4">
                Start New Wash
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var q in Model)
        {
            <div class="col-md-6">
                <div class="card border-0 shadow-sm border-start border-4
                    @(q.Status == WashStatus.Washing ? "border-primary" : "border-warning")">
                    <div class="card-body">
                        <!-- Header -->
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <span class="badge bg-dark fs-6 mb-1">
                                    #@q.QueuePosition
                                </span>
                                <h5 class="mb-0 fw-bold">
                                    @q.Transaction.Vehicle.LicensePlate
                                </h5>
                                <small class="text-muted">
                                    @q.Transaction.Customer.FullName •
                                    @q.Transaction.Customer.Phone
                                </small>
                            </div>
                            <span class="badge fs-6
                                @(q.Status == WashStatus.Washing ?
                                    "bg-primary" : "bg-warning text-dark")">
                                @q.Status
                            </span>
                        </div>

                        <!-- Services -->
                        <div class="mb-3">
                            @foreach (var ts in q.Transaction.TransactionServices)
                            {
                                <span class="badge bg-light text-dark border me-1">
                                    @ts.Service.ServiceName
                                </span>
                            }
                        </div>

                        <!-- Amount & Time -->
                        <div class="d-flex justify-content-between mb-3">
                            <span class="fw-bold text-success">
                                KES @q.Transaction.TotalAmount.ToString("N0")
                            </span>
                            <span class="text-muted small">
                                @q.Transaction.PaymentMethod •
                                @q.Transaction.CreatedAt.ToString("HH:mm")
                            </span>
                        </div>

                        @if (q.AssignedWasher != null)
                        {
                            <div class="mb-3">
                                <small class="text-muted">
                                    👤 Washer: @q.AssignedWasher.FullName
                                </small>
                            </div>
                        }

                        <!-- Actions -->
                        <div class="d-flex gap-2 flex-wrap">
                            @if (q.Status == WashStatus.Waiting)
                            {
                                <form asp-action="UpdateStatus" method="post">
                                    <input type="hidden" name="id" value="@q.QueueID" />
                                    <input type="hidden" name="status" value="1" />
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        🚿 Start Washing
                                    </button>
                                </form>
                            }

                            @if (q.Status == WashStatus.Washing)
                            {
                                <form asp-action="UpdateStatus" method="post">
                                    <input type="hidden" name="id" value="@q.QueueID" />
                                    <input type="hidden" name="status" value="2" />
                                    <button type="submit" class="btn btn-success btn-sm">
                                        ✅ Mark Complete
                                    </button>
                                </form>
                            }

                            <form asp-action="UpdateStatus" method="post"
                                  onsubmit="return confirm('Cancel this wash?')">
                                <input type="hidden" name="id" value="@q.QueueID" />
                                <input type="hidden" name="status" value="3" />
                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                    ✕ Cancel
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}