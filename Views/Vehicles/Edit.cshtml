@model SplashCityCarwash.Models.Vehicle
@{
    ViewData["Title"] = "Edit Vehicle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">✏️ Edit Vehicle</h5>
            </div>
            <div class="card-body">

                <form method="post" action="/Vehicles/Edit">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="VehicleID" value="@Model.VehicleID" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Owner</label>
                        <select name="CustomerID" class="form-select">
                            @if (ViewBag.Customers != null)
                            {
                                foreach (var item in (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.Customers)
                                {
                                    if (item.Selected)
                                    {
                            <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                            <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">License Plate</label>
                        <input name="LicensePlate" class="form-control text-uppercase"
                               value="@Model.LicensePlate" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Vehicle Type</label>
                        <select name="VehicleType" class="form-select">
                            <option value="0">Sedan</option>
                            <option value="1">SUV</option>
                            <option value="2">Truck</option>
                            <option value="3">Van</option>
                            <option value="4">Motorcycle</option>
                            <option value="5">Other</option>
                        </select>
                    </div>

                    <div class="row">
                        <div class="col mb-3">
                            <label class="form-label fw-semibold">Make</label>
                            <input name="Make" class="form-control"
                                   value="@Model.Make" placeholder="Toyota" />
                        </div>
                        <div class="col mb-3">
                            <label class="form-label fw-semibold">Car Model</label>
                            <input name="CarModel" class="form-control"
                                   value="@Model.CarModel" placeholder="Corolla" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Color</label>
                        <input name="Color" class="form-control"
                               value="@Model.Color" placeholder="Silver" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4">
                            Update
                        </button>
                        <a href="/Vehicles/Index"
                           class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>

                <hr />
                <form method="post" action="/Vehicles/Delete"
                      onsubmit="return confirm('Delete this vehicle?')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.VehicleID" />
                    <button type="submit" class="btn btn-outline-danger btn-sm">
                        🗑️ Delete Vehicle
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>
```

Save → **Build → Clean Solution** → **Build → Rebuild Solution** → then run in Package Manager Console:
```
Add-Migration RenameModelToCarModel
Update-Database