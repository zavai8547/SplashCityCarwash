@model IEnumerable<SplashCityCarwash.Models.Vehicle>
@{
    ViewData["Title"] = "Vehicles";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">🚙 Vehicles</h4>
    <a href="/Vehicles/Create" class="btn btn-success rounded-pill px-4">
        + Add Vehicle
    </a>
</div>

<form method="get" class="mb-4">
    <div class="input-group" style="max-width:400px;">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control" placeholder="Search by plate or owner..." />
        <button class="btn btn-dark" type="submit">Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <a href="/Vehicles/Index" class="btn btn-outline-secondary">Clear</a>
        }
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Plate</th>
                    <th>Type</th>
                    <th>Make / Model</th>
                    <th>Color</th>
                    <th>Owner</th>
                    <th>Phone</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            No vehicles found.
                            <a href="/Vehicles/Create">Add the first one</a>
                        </td>
                    </tr>
                }
                @foreach (var v in Model)
                {
                    <tr>
                        <td>
                            <span class="badge bg-dark fs-6">@v.LicensePlate</span>
                        </td>
                        <td>@v.VehicleType</td>
                        <td>@v.Make @v.CarModel</td>
                        <td>@v.Color</td>
                        <td>
                            <a href="/Customers/Details/@v.CustomerID"
                               class="text-decoration-none">
                                @v.Customer.FullName
                            </a>
                        </td>
                        <td>@v.Customer.Phone</td>
                        <td>
                            <a href="/Vehicles/Details/@v.VehicleID"
                               class="btn btn-sm btn-outline-primary">View</a>
                            <a href="/Vehicles/Edit/@v.VehicleID"
                               class="btn btn-sm btn-outline-secondary">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>