@model SplashCityCarwash.Models.Vehicle
@{
    ViewData["Title"] = "Add Vehicle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">🚗 Add New Vehicle</h5>
            </div>
            <div class="card-body">
                <form method="post" action="/Vehicles/Create">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Owner *</label>
                        <select name="CustomerID" class="form-select" required>
                            <option value="0">-- Select Customer --</option>
                            @if (ViewBag.Customers != null)
                            {
                                foreach (var item in
                                (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)
                                ViewBag.Customers)
                                {
                                    if (item.Selected)
                                    {
                                        <option value="@item.Value" selected>
                                            @item.Text
                                        </option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">
                                            @item.Text
                                        </option>
                                    }
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">License Plate *</label>
                        <input name="LicensePlate"
                               class="form-control text-uppercase"
                               placeholder="KCA 123A" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Vehicle Type *</label>
                        <select name="VehicleType" class="form-select" required>
                            <option value="0">Sedan</option>
                            <option value="1">SUV</option>
                            <option value="2">Truck</option>
                            <option value="3">Van</option>
                            <option value="4">Motorcycle</option>
                            <option value="5">Other</option>
                        </select>
                    </div>

                    <div class="row">
                        <div class="col mb-3">
                            <label class="form-label fw-semibold">Make</label>
                            <input name="Make" class="form-control"
                                   placeholder="Toyota" />
                        </div>
                        <div class="col mb-3">
                            <label class="form-label fw-semibold">Car Model</label>
                            <input name="CarModel" class="form-control"
                                   placeholder="Corolla" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Color</label>
                        <input name="Color" class="form-control"
                               placeholder="Silver" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4">
                            Save Vehicle
                        </button>
                        <a href="/Vehicles/Index"
                           class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>