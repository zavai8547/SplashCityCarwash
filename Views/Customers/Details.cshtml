@model SplashCityCarwash.Models.Customer
@{
    ViewData["Title"] = "Customer Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">👤 @Model.FullName</h4>
    <div class="d-flex gap-2">
        <a href="/Customers/Edit/@Model.CustomerID" class="btn btn-outline-secondary">Edit</a>
        <a href="/Customers" class="btn btn-outline-dark">← Back</a>
    </div>
</div>

<!-- Customer Info -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted mb-3">Contact Info</h6>
                <p class="mb-1"><strong>📞 Phone:</strong> @Model.Phone</p>
                <p class="mb-1"><strong>📧 Email:</strong> @(Model.Email ?? "—")</p>
                <p class="mb-1"><strong>📝 Notes:</strong> @(Model.Notes ?? "—")</p>
                <p class="mb-0"><small class="text-muted">Member since @Model.CreatedAt.ToString("dd MMM yyyy")</small></p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-success text-white">
            <div class="card-body text-center">
                <h6 class="opacity-75">Total Spent</h6>
                <h2 class="fw-bold">KES @Model.TotalSpent.ToString("N0")</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-primary text-white">
            <div class="card-body text-center">
                <h6 class="opacity-75">Total Visits</h6>
                <h2 class="fw-bold">@Model.TotalVisits</h2>
            </div>
        </div>
    </div>
</div>

<!-- Vehicles -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white fw-semibold border-0 pt-3 d-flex justify-content-between">
        <span>🚗 Vehicles (@Model.Vehicles.Count)</span>
        <a href="/Vehicles/Create?customerId=@Model.CustomerID" class="btn btn-sm btn-success">+ Add Vehicle</a>
    </div>
    <div class="card-body p-0">
        @if (!Model.Vehicles.Any())
        {
        <div class="text-center text-muted py-3">No vehicles registered</div>
        }
        else
        {
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Plate</th><th>Type</th><th>Make/Model</th><th>Color</th></tr>
            </thead>
            <tbody>
                @foreach (var v in Model.Vehicles)
                {
                <tr>
                    <td><span class="badge bg-dark">@v.LicensePlate</span></td>
                    <td>@v.VehicleType</td>
                    <td>@v.Make @v.Model</td>
                    <td>@v.Color</td>
                </tr>
                }
            </tbody>
        </table>
        }
    </div>
</div>

<!-- Transaction History -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-semibold border-0 pt-3">
        🧾 Visit History (@Model.Transactions.Count)
    </div>
    <div class="card-body p-0">
        @if (!Model.Transactions.Any())
        {
        <div class="text-center text-muted py-3">No transactions yet</div>
        }
        else
        {
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Date</th><th>Plate</th><th>Services</th><th>Amount</th><th>Status</th></tr>
            </thead>
            <tbody>
                @foreach (var t in Model.Transactions.OrderByDescending(t => t.CreatedAt))
                {
                <tr>
                    <td><small>@t.CreatedAt.ToString("dd MMM yyyy HH:mm")</small></td>
                    <td><span class="badge bg-secondary">@t.Vehicle.LicensePlate</span></td>
                    <td><small>@string.Join(", ", t.TransactionServices.Select(s => s.Service.ServiceName))</small></td>
                    <td>KES @t.TotalAmount.ToString("N0")</td>
                    <td>
                        <span class="badge bg-@(t.Status == SplashCityCarwash.Models.WashStatus.Completed ? " success" : "warning text-dark" )">
                            @t.Status
                        </span>
                    </td>
                </tr>
                }
            </tbody>
        </table>
        }
    </div>
</div>