@model IEnumerable<SplashCityCarwash.Models.Customer>
@{
    ViewData["Title"] = "Customers";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">👥 Customers</h4>
    <a href="/Customers/Create" class="btn btn-success rounded-pill px-4">+ Add Customer</a>
</div>

<!-- Search -->
<form method="get" class="mb-4">
    <div class="input-group" style="max-width:400px;">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control" placeholder="Search by name or phone..." />
        <button class="btn btn-dark" type="submit">Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <a href="/Customers" class="btn btn-outline-secondary">Clear</a>
        }
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Email</th>
                    <th>Visits</th>
                    <th>Total Spent</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            No customers found.
                            <a href="/Customers/Create">Add the first one</a>
                        </td>
                    </tr>
                }
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.CustomerID</td>
                        <td class="fw-semibold">@c.FullName</td>
                        <td>@c.Phone</td>
                        <td>@(c.Email ?? "—")</td>
                        <td><span class="badge bg-info text-dark">@c.TotalVisits</span></td>
                        <td>KES @c.TotalSpent.ToString("N0")</td>
                        <td><small class="text-muted">@c.CreatedAt.ToString("dd MMM yyyy")</small></td>
                        <td>
                            <a href="/Customers/Details/@c.CustomerID" class="btn btn-sm btn-outline-primary">View</a>
                            <a href="/Customers/Edit/@c.CustomerID" class="btn btn-sm btn-outline-secondary">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>